# Kopieren zu .env und ausfüllen
# Wird automatisch befüllt durch: ./scripts/deploy-tenant.sh

DB_USER=jagd
DB_NAME=jagdscheissen
DB_PASSWORD=

# Mindestens 32 Zeichen — wird automatisch generiert durch deploy-tenant.sh
JWT_SECRET=

# URL des Frontends (für CORS) — wird automatisch gesetzt durch deploy-tenant.sh
CORS_ORIGIN=https://ihre-subdomain.ihre-domain.de

# Setzt secure-Flag am JWT-Cookie (true in Produktion, false lokal)
COOKIE_SECURE=false

# Anzeigename der App-Instanz (erscheint im Setup-Wizard und Browser-Titel)
VITE_APP_TITLE=JagdSchießen
