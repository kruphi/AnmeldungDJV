# Kopieren zu .env und ausfüllen
# Wird automatisch befüllt durch: ./scripts/add-app.sh

POSTGRES_USER=jagd
DB_PASSWORD=
POSTGRES_DB=jagdscheissen

# Mindestens 32 Zeichen — wird automatisch generiert durch add-app.sh
JWT_SECRET=

# URL des Frontends (für CORS) — wird automatisch gesetzt durch add-app.sh
CORS_ORIGIN=https://ihre-subdomain.ihre-domain.de

# Setzt secure-Flag am JWT-Cookie (true in Produktion, false lokal)
COOKIE_SECURE=false

# Anzeigename der App-Instanz (erscheint im Setup-Wizard und Browser-Titel)
VITE_APP_TITLE=JagdSchießen
